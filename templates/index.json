                    "settings": {
                        "question": "What does buying a vendor bundle get me?",
                        "answer": "<p>Buying a vendor bundle gets you instant access to several trusted, reliable suppliers that sells quality products at competitive prices. This allows you to source items efficiently for your needs.<\/p>"
                    }
                },
                "faq_item_VM7BeA": {
                    "type": "faq_item",
                    "settings": {
                        "question": "How will I receive access to the vendor?",
                        "answer": "<p>Once you complete your purchase, the supplier's contact is INSTANTLY sent via email and will be available immediately on the order confirmation page.<\/p>"
                    }
                },
                "faq_item_8tmnrb": {
                    "type": "faq_item",
                    "settings": {
                        "question": "How long does the vendor take to ship?",
                        "answer": "<p>Shipping times range from 2-7 days, and rarely take longer. The most common shipment time is about a week. You can ask the vendors for accurate shipment times.<\/p>"
                    }
                },
                "faq_item_yP4J3m": {
                    "type": "faq_item",
                    "settings": {
                        "question": "Do the vendors ship worldwide?",
                        "answer": "<p>Yes! These suppliers ship worldwide, no matter where you're located. You don't have to worry about not being able to access them in your country.<\/p>"
                    }
                },
                "faq_item_qezeQf": {
                    "type": "faq_item",
                    "settings": {
                        "question": "How much do the vendors charge for a product?",
                        "answer": "<p>The vendors charge anywhere from $10-$100 per product. Some are cheaper than others.<\/p>"
                    }
                },
                "faq_item_RyeLE8": {
                    "type": "faq_item",
                    "settings": {
                        "question": "What if I can't find my order?",
                        "answer": "<p>Your order will be available for download directly after checkout and an email containing the vendor will be sent to you immediately.<\/p><p>If you still can't find them, open a ticket in my discord and I will personally help you.<\/p>"
                    }
                }
